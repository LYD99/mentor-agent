# Environment Variables Template
# Copy this file to .env and fill in your values

# DATABASE
# SQLite 数据库文件路径（相对于 prisma/schema.prisma 的位置）
DATABASE_URL=file:./data/app.db

# AUTH
# NextAuth.js 使用的密钥（启动脚本会自动生成）
AUTH_SECRET=
# 应用的基础 URL
AUTH_URL=http://localhost:3000

# AI
# AI API 密钥
AI_API_KEY=your-api-key-here
# AI API 基础 URL（可选，用于代理）
AI_BASE_URL=https://api.openai.com
# AI 模型名称（默认模型，如 deepseek-chat, gpt-4o-mini 等）
AI_MODEL=deepseek-chat

# 可选：为不同 Agent 配置专用模型（未设置时使用 AI_MODEL）
# LESSON_AGENT_MODEL=gpt-4o
# ADVISOR_AGENT_MODEL=gpt-4o
# PLAN_AGENT_MODEL=gpt-4o
# SCHEDULE_AGENT_MODEL=gpt-4o-mini

# 研究功能（可选）
# TAVILY_API_KEY=your-tavily-key

# 质量控制（可选）
# ENABLE_QUALITY_VALIDATION=true  # 是否启用质量验证
# QUALITY_VALIDATION_MODE="rule-based&llm-based"  # 验证模式：rule-based 或 rule-based&llm-based
# MIN_QUALITY_SCORE=70  # 规则检查阈值（0-100）
# LLM_QUALITY_MIN_SCORE=75  # LLM 评估阈值（0-100，仅 rule-based&llm-based 模式需要）
# ENABLE_LLM_QUALITY_ASSESSMENT=true  # 内部配置，由验证模式自动控制

# 并发控制（可选）
# SCHEDULE_BATCH_CONCURRENCY=5  # Schedule Agent 批次生成并发数（默认 5）

# ENCRYPTION
# 数据加密密钥（用于加密 RAG API Key 等敏感信息，启动脚本会自动生成）
ENCRYPTION_KEY=

# STORAGE
# Session 文件存储路径
# STORAGE_PATH=./data/local/sessions

# GENERAL
# 应用运行环境
# NODE_ENV=development
# 应用监听端口
# PORT=3000
