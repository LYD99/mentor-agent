# Environment Variables Template
# Copy this file to .env and fill in your values

# DATABASE
# SQLite 数据库文件路径
DATABASE_URL=file:./prisma/data/app.db

# AUTH
# NextAuth.js 使用的密钥（使用 openssl rand -base64 32 生成）
AUTH_SECRET=your-secret-here
# 应用的基础 URL
AUTH_URL=http://localhost:3000

# AI
# AI API 密钥
AI_API_KEY=your-api-key-here
# AI API 基础 URL（可选，用于代理）
AI_BASE_URL=https://api.openai.com
# AI 模型名称（如 deepseek-chat, gpt-4o-mini 等）
AI_MODEL=gpt-4o-mini

# ENCRYPTION
# 数据加密密钥（用于加密 RAG API Key 等敏感信息）
# 使用 node -e "console.log(require('crypto').randomBytes(32).toString('hex'))" 生成
ENCRYPTION_KEY=your-64-char-hex-key-here

# STORAGE
# Session 文件存储路径
# STORAGE_PATH=./data/local/sessions

# GENERAL
# 应用运行环境
# NODE_ENV=development
# 应用监听端口
# PORT=3000
